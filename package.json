{
	"name": "cv-site",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"pages:dev": "pnpm wrangler pages dev .svelte-kit/cloudflare --live-reload --persist-to .wrangler/state/v3/pages/dev/cv-site/kv/",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:security": "node scripts/security-test.mjs",
		"test:with-server": "node scripts/test-with-server.mjs",
		"validate": "pnpm run format && pnpm run lint && pnpm run check",
		"deploy:check": "echo '🔍 Running validation...' && pnpm run validate && echo '🏗️ Running build...' && pnpm run build && echo '🔒 Starting server and running security tests...' && pnpm run test:with-server && echo '✅ All checks passed!'"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260510.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.2",
		"@vitest/ui": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"jsdom": "^25.0.1",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5",
		"wrangler": "4.90.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@firebase/util",
			"@parcel/watcher",
			"@tailwindcss/oxide",
			"esbuild",
			"protobufjs",
			"sharp",
			"workerd"
		],
		"overrides": {
			"protobufjs@<7.5.5": ">=7.5.5"
		}
	},
	"dependencies": {
		"firebase": "^12.13.0",
		"groq-sdk": "^1.1.2",
		"node-fetch": "^3.3.2",
		"rate-limiter-flexible": "^11.1.0"
	}
}
