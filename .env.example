# Copy this file to .env.local and fill in real values for local dev.
# .env.local is gitignored. In production, the same names must be set as
# Pages secrets in the Cloudflare dashboard (Settings → Variables & Secrets).
#
# All VITE_-prefixed values get inlined into the client bundle at build time
# — they're public information that already appears on the rendered page.

# === Server-only secrets ===
GROQ_API_KEY=
TURNSTILE_SECRET=
# 48 random bytes, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=
# 48 random bytes, base64. MUST be different from SESSION_SECRET.
VISITOR_LOG_SALT=

# === Client-exposed (VITE_*) ===
# Firebase web config as a single JSON string.
# Get from Firebase console → Project settings → Web app → Config.
VITE_FIREBASE_CONFIG=
# Cloudflare Turnstile site key (the *public* one, not the secret).
VITE_TURNSTILE_SITEKEY=

# Personal profile (sidebar, page title, AI system prompt). Empty = hidden.
VITE_PROFILE_NAME=Jane Doe
VITE_PROFILE_ROLE=Cloud Architect
VITE_PROFILE_LOCATION=Madrid · Open to roles

# Personal URLs/emails. Empty = the corresponding UI is hidden.
VITE_CALENDLY_URL=https://calendly.com/your-username
VITE_LINKEDIN_URL=https://www.linkedin.com/in/your-handle
VITE_CONTACT_EMAIL=you@example.com
